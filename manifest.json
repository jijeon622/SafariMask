{
  "manifest_version": 2,

  "name": "Safari Mask",
  "version": "2.0",

  "browser_specific_settings": {
    "gecko": {
      "id": "safari-mask@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "browser_action": {
    "default_title": "Safari Mask",
    "default_popup": "popup.html"
  },

  "web_accessible_resources": [
  "inject.js"
  ]
}